# ============================================================
# NCAP VMS — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to git
# ============================================================

# Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT secret — make this long and random (e.g. generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_this_with_a_long_random_string_at_least_64_chars

# JWT expiry (how long login tokens last)
JWT_EXPIRES_IN=12h

# Port (Railway/Render set this automatically — leave as 3000 for local)
PORT=3000

# Frontend URL for CORS (update to your deployed frontend URL)
# For local dev use: http://localhost:3000
# For Render/Vercel: https://your-app-name.onrender.com
FRONTEND_URL=http://localhost:3000

# Node environment
NODE_ENV=development
